{
	"$schema": "https://opencode.ai/config.json",
	"permission": {
		"external_directory": {
			"../ito-worktrees/**": "allow",
			"../../ito/**": "allow"
		}
	},
	"formatter": {
		"cargofmt": {
			"disabled": true
		},
		"rustfmt": {
			"disabled": true
		},
		"prek-manual": {
			"command": [
				"prek",
				"run",
				"--config",
				".pre-commit-opencode.yaml",
				"--hook-stage",
				"manual",
				"--files",
				"$FILE"
			],
			"extensions": [
				".rs",
				".md",
				".txt",
				".toml",
				".lock",
				".json",
				".jsonc",
				".yaml",
				".yml",
				".sh",
				".py",
				".editorconfig",
				".gitignore",
				".gitattributes"
			]
		}
	}
}
