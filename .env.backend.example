# Example environment variables for Ito backend Docker Compose runtime.
#
# Copy this file to `.env.backend` and adjust values for your local environment.
# Then run: docker compose -f docker-compose.backend.yml up -d

# Port exposed on the Docker host (default: 9010)
ITO_BACKEND_PORT=9010

# Admin bearer token (full access to all projects). Required.
# Generate a secure random token for production use.
ITO_BACKEND_ADMIN_TOKEN=dev-admin-token

# HMAC-SHA256 seed used to derive per-project bearer tokens.
# Required if you want per-project token derivation.
ITO_BACKEND_TOKEN_SEED=dev-token-seed
