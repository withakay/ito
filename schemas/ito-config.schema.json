{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "AgentModelOptions": {
      "additionalProperties": true,
      "description": "Extended agent model options",
      "properties": {
        "model": {
          "description": "Model identifier",
          "examples": [
            "openai/gpt-5.2-codex"
          ],
          "type": "string"
        },
        "reasoningEffort": {
          "anyOf": [
            {
              "$ref": "#/definitions/ReasoningEffort"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Reasoning effort (OpenAI)"
        },
        "steps": {
          "default": null,
          "description": "Optional max steps for tool loops",
          "format": "uint64",
          "minimum": 0.0,
          "type": [
            "integer",
            "null"
          ]
        },
        "temperature": {
          "default": null,
          "description": "Temperature (0.0-1.0)",
          "format": "double",
          "maximum": 1.0,
          "minimum": 0.0,
          "type": [
            "number",
            "null"
          ]
        },
        "textVerbosity": {
          "anyOf": [
            {
              "$ref": "#/definitions/TextVerbosity"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Text verbosity"
        },
        "top_p": {
          "default": null,
          "description": "Top-p sampling (0.0-1.0)",
          "format": "double",
          "maximum": 1.0,
          "minimum": 0.0,
          "type": [
            "number",
            "null"
          ]
        },
        "variant": {
          "default": null,
          "description": "Optional variant selector (OpenCode)",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "model"
      ],
      "type": "object"
    },
    "AgentModelSetting": {
      "anyOf": [
        {
          "description": "Shorthand setting using only a model identifier.",
          "type": "string"
        },
        {
          "allOf": [
            {
              "$ref": "#/definitions/AgentModelOptions"
            }
          ],
          "description": "Extended options object."
        }
      ],
      "description": "Agent model setting: shorthand string or options object"
    },
    "AgentTiersConfig": {
      "description": "Agent tier to model mapping",
      "properties": {
        "ito-general": {
          "allOf": [
            {
              "$ref": "#/definitions/AgentModelSetting"
            }
          ],
          "description": "Balanced tier"
        },
        "ito-quick": {
          "allOf": [
            {
              "$ref": "#/definitions/AgentModelSetting"
            }
          ],
          "description": "Fast, cheap tier"
        },
        "ito-thinking": {
          "allOf": [
            {
              "$ref": "#/definitions/AgentModelSetting"
            }
          ],
          "description": "High-capability tier"
        }
      },
      "required": [
        "ito-general",
        "ito-quick",
        "ito-thinking"
      ],
      "type": "object"
    },
    "ArchiveConfig": {
      "description": "Archive integration settings",
      "properties": {
        "main_integration_mode": {
          "allOf": [
            {
              "$ref": "#/definitions/ArchiveMainIntegrationMode"
            }
          ],
          "default": "pull_request",
          "description": "Default mode for integrating archived changes into main"
        }
      },
      "type": "object"
    },
    "ArchiveMainIntegrationMode": {
      "description": "Archive integration mode for promoting archived changes into main",
      "oneOf": [
        {
          "description": "Integrate archived changes directly into `main`.",
          "enum": [
            "direct_merge"
          ],
          "type": "string"
        },
        {
          "description": "Create a pull request for `main` integration.",
          "enum": [
            "pull_request"
          ],
          "type": "string"
        },
        {
          "description": "Create a pull request and request automatic merge.",
          "enum": [
            "pull_request_auto_merge"
          ],
          "type": "string"
        },
        {
          "description": "Archive on the coordination branch only and leave `main` integration for later.",
          "enum": [
            "coordination_only"
          ],
          "type": "string"
        }
      ]
    },
    "AuditConfig": {
      "description": "Audit configuration",
      "properties": {
        "mirror": {
          "allOf": [
            {
              "$ref": "#/definitions/AuditMirrorConfig"
            }
          ],
          "default": {
            "branch": "ito/internal/audit",
            "enabled": false
          },
          "description": "Remote mirroring settings"
        }
      },
      "type": "object"
    },
    "AuditMirrorConfig": {
      "description": "Audit remote mirroring settings",
      "properties": {
        "branch": {
          "default": "ito/internal/audit",
          "description": "Remote branch name used for audit mirroring",
          "type": "string"
        },
        "enabled": {
          "default": false,
          "description": "Enable best-effort audit remote mirroring",
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "BackendAllowlistConfig": {
      "description": "Organization and repository allowlist",
      "properties": {
        "orgs": {
          "default": [],
          "description": "Allowed organizations",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "repos": {
          "additionalProperties": {
            "$ref": "#/definitions/BackendRepoPolicy"
          },
          "default": {},
          "description": "Per-org repo policies: org -> '*' or list of repos",
          "type": "object"
        }
      },
      "type": "object"
    },
    "BackendApiConfig": {
      "description": "Backend state API configuration",
      "properties": {
        "backup_dir": {
          "description": "Per-user backup directory for artifact snapshots",
          "type": [
            "string",
            "null"
          ]
        },
        "enabled": {
          "default": false,
          "description": "Enable backend API integration",
          "type": "boolean"
        },
        "max_retries": {
          "default": 3,
          "description": "Maximum retry attempts for transient failures",
          "format": "uint32",
          "minimum": 0.0,
          "type": "integer"
        },
        "project": {
          "allOf": [
            {
              "$ref": "#/definitions/BackendProjectConfig"
            }
          ],
          "default": {},
          "description": "Project namespace for backend routing"
        },
        "timeout_ms": {
          "default": 30000,
          "description": "Request timeout in milliseconds",
          "format": "uint64",
          "minimum": 0.0,
          "type": "integer"
        },
        "token": {
          "description": "Authentication token for backend API access",
          "type": [
            "string",
            "null"
          ]
        },
        "token_env_var": {
          "default": "ITO_BACKEND_TOKEN",
          "description": "Environment variable name that holds the bearer token",
          "type": "string"
        },
        "url": {
          "default": "http://127.0.0.1:9010",
          "description": "Base URL for the backend API",
          "type": "string"
        }
      },
      "type": "object"
    },
    "BackendAuthConfig": {
      "description": "Backend authentication configuration",
      "properties": {
        "adminTokens": {
          "default": [],
          "description": "Admin bearer tokens with full access",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "tokenSeed": {
          "description": "Secret seed for deriving per-project tokens via HMAC-SHA256",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "BackendCorsConfig": {
      "description": "CORS configuration",
      "properties": {
        "origins": {
          "description": "Allowed CORS origins (None = permissive)",
          "items": {
            "type": "string"
          },
          "type": [
            "array",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "BackendHttpConfig": {
      "description": "HTTP transport configuration",
      "properties": {
        "maxBodyBytes": {
          "default": 10485760,
          "description": "Maximum HTTP request body size in bytes",
          "format": "uint",
          "minimum": 0.0,
          "type": "integer"
        }
      },
      "type": "object"
    },
    "BackendProjectConfig": {
      "description": "Project namespace for backend API routing",
      "properties": {
        "org": {
          "description": "Organization namespace for backend routes",
          "type": [
            "string",
            "null"
          ]
        },
        "repo": {
          "description": "Repository namespace for backend routes",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "BackendRepoPolicy": {
      "anyOf": [
        {
          "description": "Allow all repositories for this organization.",
          "type": "string"
        },
        {
          "description": "Allow only the listed repositories.",
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      ],
      "description": "Repo policy: '*' for all or list of repo names"
    },
    "BackendServerConfig": {
      "description": "Backend server configuration for multi-tenant API hosting",
      "properties": {
        "allowed": {
          "allOf": [
            {
              "$ref": "#/definitions/BackendAllowlistConfig"
            }
          ],
          "default": {
            "orgs": [],
            "repos": {}
          },
          "description": "Allowlist for organizations and repositories"
        },
        "auth": {
          "allOf": [
            {
              "$ref": "#/definitions/BackendAuthConfig"
            }
          ],
          "default": {
            "adminTokens": []
          },
          "description": "Authentication configuration"
        },
        "bind": {
          "default": "127.0.0.1",
          "description": "Bind address for the server",
          "type": "string"
        },
        "cors": {
          "allOf": [
            {
              "$ref": "#/definitions/BackendCorsConfig"
            }
          ],
          "default": {},
          "description": "CORS configuration"
        },
        "dataDir": {
          "description": "Storage root directory for backend-managed project data",
          "type": [
            "string",
            "null"
          ]
        },
        "enabled": {
          "default": false,
          "description": "Enable backend server features",
          "type": "boolean"
        },
        "http": {
          "allOf": [
            {
              "$ref": "#/definitions/BackendHttpConfig"
            }
          ],
          "default": {
            "maxBodyBytes": 10485760
          },
          "description": "HTTP transport settings"
        },
        "port": {
          "default": 9010,
          "description": "Port for the server",
          "format": "uint16",
          "minimum": 0.0,
          "type": "integer"
        },
        "storage": {
          "allOf": [
            {
              "$ref": "#/definitions/BackendStorageConfig"
            }
          ],
          "default": {
            "kind": "filesystem",
            "sqlite": {}
          },
          "description": "Storage backend configuration"
        }
      },
      "type": "object"
    },
    "BackendSqliteConfig": {
      "description": "SQLite backend configuration",
      "properties": {
        "dbPath": {
          "description": "Path to the SQLite database file",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "BackendStorageConfig": {
      "description": "Storage backend configuration",
      "properties": {
        "kind": {
          "allOf": [
            {
              "$ref": "#/definitions/BackendStorageKind"
            }
          ],
          "default": "filesystem",
          "description": "Storage backend kind: filesystem or sqlite"
        },
        "sqlite": {
          "allOf": [
            {
              "$ref": "#/definitions/BackendSqliteConfig"
            }
          ],
          "default": {},
          "description": "SQLite-specific configuration"
        }
      },
      "type": "object"
    },
    "BackendStorageKind": {
      "description": "Storage backend kind",
      "oneOf": [
        {
          "description": "Filesystem-backed markdown storage (default).",
          "enum": [
            "filesystem"
          ],
          "type": "string"
        },
        {
          "description": "SQLite-backed storage (proof-of-concept).",
          "enum": [
            "sqlite"
          ],
          "type": "string"
        }
      ]
    },
    "CacheConfig": {
      "description": "Cache settings",
      "properties": {
        "ttl_hours": {
          "default": 24,
          "description": "Model registry cache TTL in hours",
          "format": "uint64",
          "minimum": 0.0,
          "type": "integer"
        }
      },
      "type": "object"
    },
    "ChangesConfig": {
      "description": "Change coordination settings",
      "properties": {
        "archive": {
          "allOf": [
            {
              "$ref": "#/definitions/ArchiveConfig"
            }
          ],
          "default": {
            "main_integration_mode": "pull_request"
          },
          "description": "Archive integration settings"
        },
        "coordination_branch": {
          "allOf": [
            {
              "$ref": "#/definitions/CoordinationBranchConfig"
            }
          ],
          "default": {
            "enabled": true,
            "name": "ito/internal/changes",
            "storage": "worktree",
            "sync_interval_seconds": 120
          },
          "description": "Coordination branch settings"
        }
      },
      "type": "object"
    },
    "ClaudeCodeHarnessConfig": {
      "description": "Claude Code harness configuration",
      "properties": {
        "agents": {
          "allOf": [
            {
              "$ref": "#/definitions/AgentTiersConfig"
            }
          ],
          "default": {
            "ito-general": "sonnet",
            "ito-quick": "haiku",
            "ito-thinking": "opus"
          },
          "description": "Ito agent tier model mappings"
        },
        "provider": {
          "anyOf": [
            {
              "$ref": "#/definitions/ProviderAnthropic"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Provider constraint (if specified, must be anthropic)"
        }
      },
      "type": "object"
    },
    "CodexHarnessConfig": {
      "description": "Codex harness configuration",
      "properties": {
        "agents": {
          "allOf": [
            {
              "$ref": "#/definitions/AgentTiersConfig"
            }
          ],
          "default": {
            "ito-general": {
              "model": "openai/gpt-5.2-codex",
              "reasoningEffort": "high",
              "steps": null,
              "temperature": null,
              "textVerbosity": null,
              "top_p": null,
              "variant": null
            },
            "ito-quick": "openai/gpt-5.1-codex-mini",
            "ito-thinking": {
              "model": "openai/gpt-5.2-codex",
              "reasoningEffort": "xhigh",
              "steps": null,
              "temperature": null,
              "textVerbosity": null,
              "top_p": null,
              "variant": null
            }
          },
          "description": "Ito agent tier model mappings"
        },
        "provider": {
          "anyOf": [
            {
              "$ref": "#/definitions/ProviderOpenAi"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Provider constraint (if specified, must be openai)"
        }
      },
      "type": "object"
    },
    "CoordinationBranchConfig": {
      "description": "Dedicated branch used for proposal/task coordination",
      "properties": {
        "enabled": {
          "default": true,
          "description": "Enable change coordination branch synchronization",
          "type": "boolean"
        },
        "name": {
          "default": "ito/internal/changes",
          "description": "Name of the internal coordination branch",
          "type": "string"
        },
        "storage": {
          "allOf": [
            {
              "$ref": "#/definitions/CoordinationStorage"
            }
          ],
          "default": "worktree",
          "description": "Storage backend for coordination data"
        },
        "sync_interval_seconds": {
          "default": 120,
          "description": "Minimum interval in seconds between redundant coordination sync pushes",
          "format": "uint64",
          "minimum": 1.0,
          "type": "integer"
        },
        "worktree_path": {
          "description": "Worktree path override for coordination storage",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "CoordinationStorage": {
      "description": "Storage backend for coordination data",
      "oneOf": [
        {
          "description": "Store coordination data in the git worktree (default).",
          "enum": [
            "worktree"
          ],
          "type": "string"
        },
        {
          "description": "Store coordination data embedded in the repository.",
          "enum": [
            "embedded"
          ],
          "type": "string"
        }
      ]
    },
    "CoverageDefaults": {
      "description": "Coverage defaults",
      "properties": {
        "target_percent": {
          "default": 80,
          "description": "Target coverage percentage",
          "format": "uint64",
          "minimum": 0.0,
          "type": "integer"
        }
      },
      "type": "object"
    },
    "DefaultsConfig": {
      "description": "Defaults section",
      "properties": {
        "testing": {
          "allOf": [
            {
              "$ref": "#/definitions/TestingDefaults"
            }
          ],
          "default": {
            "coverage": {
              "target_percent": 80
            },
            "tdd": {
              "workflow": "red-green-refactor"
            }
          },
          "description": "Testing-related defaults"
        }
      },
      "type": "object"
    },
    "GitHubCopilotHarnessConfig": {
      "description": "GitHub Copilot harness configuration",
      "properties": {
        "agents": {
          "allOf": [
            {
              "$ref": "#/definitions/AgentTiersConfig"
            }
          ],
          "default": {
            "ito-general": "github-copilot/gpt-5.2-codex",
            "ito-quick": "github-copilot/claude-haiku-4.5",
            "ito-thinking": "github-copilot/gpt-5.2-codex"
          },
          "description": "Ito agent tier model mappings"
        },
        "provider": {
          "anyOf": [
            {
              "$ref": "#/definitions/ProviderGitHubCopilot"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Provider constraint (if specified, must be github-copilot)"
        }
      },
      "type": "object"
    },
    "HarnessesConfig": {
      "description": "Harness configurations",
      "properties": {
        "claude-code": {
          "allOf": [
            {
              "$ref": "#/definitions/ClaudeCodeHarnessConfig"
            }
          ],
          "default": {
            "agents": {
              "ito-general": "sonnet",
              "ito-quick": "haiku",
              "ito-thinking": "opus"
            },
            "provider": "anthropic"
          },
          "description": "Claude Code harness settings"
        },
        "codex": {
          "allOf": [
            {
              "$ref": "#/definitions/CodexHarnessConfig"
            }
          ],
          "default": {
            "agents": {
              "ito-general": {
                "model": "openai/gpt-5.2-codex",
                "reasoningEffort": "high",
                "steps": null,
                "temperature": null,
                "textVerbosity": null,
                "top_p": null,
                "variant": null
              },
              "ito-quick": "openai/gpt-5.1-codex-mini",
              "ito-thinking": {
                "model": "openai/gpt-5.2-codex",
                "reasoningEffort": "xhigh",
                "steps": null,
                "temperature": null,
                "textVerbosity": null,
                "top_p": null,
                "variant": null
              }
            },
            "provider": "openai"
          },
          "description": "OpenAI Codex harness settings"
        },
        "github-copilot": {
          "allOf": [
            {
              "$ref": "#/definitions/GitHubCopilotHarnessConfig"
            }
          ],
          "default": {
            "agents": {
              "ito-general": "github-copilot/gpt-5.2-codex",
              "ito-quick": "github-copilot/claude-haiku-4.5",
              "ito-thinking": "github-copilot/gpt-5.2-codex"
            },
            "provider": "github-copilot"
          },
          "description": "GitHub Copilot harness settings"
        },
        "opencode": {
          "allOf": [
            {
              "$ref": "#/definitions/OpenCodeHarnessConfig"
            }
          ],
          "default": {
            "agents": {
              "ito-general": {
                "model": "openai/gpt-5.2-codex",
                "reasoningEffort": null,
                "steps": null,
                "temperature": 0.3,
                "textVerbosity": null,
                "top_p": null,
                "variant": "high"
              },
              "ito-quick": "anthropic/claude-haiku-4-5",
              "ito-thinking": {
                "model": "openai/gpt-5.2-codex",
                "reasoningEffort": null,
                "steps": null,
                "temperature": 0.5,
                "textVerbosity": null,
                "top_p": null,
                "variant": "xhigh"
              }
            },
            "provider": null
          },
          "description": "OpenCode harness settings"
        }
      },
      "type": "object"
    },
    "IntegrationMode": {
      "description": "Integration mode after implementation",
      "oneOf": [
        {
          "description": "Commit and open a PR workflow.",
          "enum": [
            "commit_pr"
          ],
          "type": "string"
        },
        {
          "description": "Merge into parent branch workflow.",
          "enum": [
            "merge_parent"
          ],
          "type": "string"
        }
      ]
    },
    "InvalidCommandsConfig": {
      "description": "Invalid command logging settings",
      "properties": {
        "enabled": {
          "default": false,
          "description": "Enable logging of invalid commands",
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "LoggingConfig": {
      "description": "Logging configuration",
      "properties": {
        "invalidCommands": {
          "allOf": [
            {
              "$ref": "#/definitions/InvalidCommandsConfig"
            }
          ],
          "default": {
            "enabled": false
          },
          "description": "Invalid command logging settings"
        }
      },
      "type": "object"
    },
    "MemoryConfig": {
      "additionalProperties": false,
      "description": "Agent memory provider configuration",
      "properties": {
        "capture": {
          "anyOf": [
            {
              "$ref": "#/definitions/MemoryOpConfig"
            },
            {
              "type": "null"
            }
          ],
          "description": "Provider for the `capture` (store / curate) operation"
        },
        "query": {
          "anyOf": [
            {
              "$ref": "#/definitions/MemoryOpConfig"
            },
            {
              "type": "null"
            }
          ],
          "description": "Provider for the `query` (synthesized answer) operation"
        },
        "search": {
          "anyOf": [
            {
              "$ref": "#/definitions/MemoryOpConfig"
            },
            {
              "type": "null"
            }
          ],
          "description": "Provider for the `search` (ranked lookup) operation"
        }
      },
      "type": "object"
    },
    "MemoryOpConfig": {
      "description": "Per-operation memory provider shape",
      "oneOf": [
        {
          "additionalProperties": false,
          "description": "Delegate the operation to an installed skill.",
          "properties": {
            "kind": {
              "enum": [
                "skill"
              ],
              "type": "string"
            },
            "options": {
              "description": "Opaque JSON options passed through verbatim to the skill."
            },
            "skill": {
              "description": "Identifier of an installed skill (resolvable under any known skills directory).",
              "type": "string"
            }
          },
          "required": [
            "kind",
            "skill"
          ],
          "type": "object"
        },
        {
          "additionalProperties": false,
          "description": "Render an inline shell command line with placeholder substitution.",
          "properties": {
            "command": {
              "description": "Shell command template with `{placeholder}` substitution markers.",
              "type": "string"
            },
            "kind": {
              "enum": [
                "command"
              ],
              "type": "string"
            }
          },
          "required": [
            "command",
            "kind"
          ],
